<?xml version="1.0" encoding="utf-8"?>
<!-- res/navigation/nav_graph_admin.xml -->
<!-- Crea este archivo en res/navigation/ (misma carpeta que tu nav_graph.xml actual) -->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_admin"
    app:startDestination="@id/adminProductosFragment">

    <!-- Lista de productos -->
    <fragment
        android:id="@+id/adminProductosFragment"
        android:name="com.example.proyecto1_android.ui.admin.AdminProductosFragment"
        android:label="Productos"
        tools:layout="@layout/fragment_admin_productos">

        <!-- Navegación al formulario (crear o editar) -->
        <action
            android:id="@+id/action_adminProductos_to_adminFormulario"
            app:destination="@id/adminFormularioFragment"/>
    </fragment>

    <!-- Formulario crear/editar -->
    <fragment
        android:id="@+id/adminFormularioFragment"
        android:name="com.example.proyecto1_android.ui.admin.AdminFormularioFragment"
        android:label="Producto"
        tools:layout="@layout/fragment_admin_formulario">

        <!-- Argumento: productoId = -1 para crear, id real para editar -->
        <argument
            android:name="productoId"
            app:argType="long"
            android:defaultValue="-1L"/>
    </fragment>

</navigation>