<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ← AGREGA ESTO -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            app:navigationIcon="@drawable/ic_back"
            app:navigationContentDescription="Regresar"
            app:title="Detalle"/>

        <!-- Imagen grande del producto -->
        <ImageView
            android:id="@+id/ivProducto"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:scaleType="centerInside"
            android:background="#F8FAFC"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Badge de categoría -->
            <TextView
                android:id="@+id/tvCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_categoria"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textColor="#4F46E5"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"/>

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginTop="12dp"/>

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#4F46E5"
                android:layout_marginTop="8dp"/>

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#64748B"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginTop="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F5F9"
                android:layout_marginVertical="20dp"/>

            <!-- Selector de cantidad — equivalente a updateQty() en detalle.php -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cantidad"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_qty_selector"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btnMenos"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="-"
                        android:textSize="18sp"
                        android:padding="0dp"
                        style="@style/Widget.Material3.Button.TextButton"/>

                    <TextView
                        android:id="@+id/tvCantidad"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:text="1"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <Button
                        android:id="@+id/btnMas"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:padding="0dp"
                        style="@style/Widget.Material3.Button.TextButton"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Botón añadir al carrito -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAgregarCarrito"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Añadir al Carrito"
                android:textSize="15sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_carrito"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>