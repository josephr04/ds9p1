<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_login.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Panel superior con gradiente (como el left-panel web) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="@drawable/bg_login_gradient"
            android:gravity="bottom">

            <!-- Pill "Sistema activo" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_active"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEMA ACTIVO"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textColor="#CCFFFFFF"/>
            </LinearLayout>

            <!-- Título grande -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sellflow"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="8dp"/>

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa tus credenciales para continuar"
                android:textSize="13sp"
                android:textColor="#99FFFFFF"/>

        </LinearLayout>

        <!-- ── Formulario (como el right-panel web) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="#FFFFFF">

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCESO AL SISTEMA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#4F46E5"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="4dp"/>

            <!-- Título del form -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar sesión"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa tus credenciales para continuar."
                android:textSize="13sp"
                android:textColor="#64748B"
                android:layout_marginBottom="28dp"/>

            <!-- Campo Usuario -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuario"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#E2E8F0"
                app:boxStrokeWidth="1.5dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="#94A3B8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tu nombre de usuario"
                    android:inputType="text"
                    android:imeOptions="actionNext"
                    android:textSize="14sp"
                    android:textColor="#0F172A"
                    android:background="@android:color/transparent"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Campo Contraseña -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#E2E8F0"
                app:boxStrokeWidth="1.5dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#94A3B8"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tu contraseña"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:textSize="14sp"
                    android:textColor="#0F172A"
                    android:background="@android:color/transparent"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Entrar"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#4F46E5"
                app:cornerRadius="10dp"
                android:layout_marginBottom="20dp"/>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ── Stats footer (como el left-footer web) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F8FAFF"
            android:padding="28dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roles de acceso"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#E2E8F0"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguro"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#E2E8F0"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24/7"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disponible"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>